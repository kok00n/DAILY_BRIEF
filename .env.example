# === LLM / research keys ===
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...
XAI_API_KEY=xai-...

# Free, register at https://fredaccount.stlouisfed.org/apikeys (1 min)
FRED_API_KEY=...

# Free CNB ARAD key — unlocks the DAILY Czech 10Y govbond yield (CZ in the CEE
# rates table). Register (free, ~1 min) at https://www.cnb.cz/arad/ ; the API key
# is shown in your account. Optional: without it, CZ falls back to the monthly
# FRED/OECD figure (flagged "dane miesięczne" in the brief).
CNB_API_KEY=...

# === Cloudflare R2 (S3-compatible object storage for MP3 + RSS feed) ===
# Create a bucket, an R2 API token (Access Key ID + Secret), and enable a
# public dev URL (or custom domain) for the bucket.
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=daily-brief
# Public base URL of the bucket, e.g. https://pub-xxxxxxxx.r2.dev  (no trailing slash)
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev
